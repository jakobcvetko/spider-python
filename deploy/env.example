# Copy to /opt/spider/.env on the Hetzner server (never commit .env).

# GHCR image (lowercase), e.g. ghcr.io/youruser/spider-python
SPIDER_IMAGE=ghcr.io/YOUR_GITHUB_USER/spider-python
# Set by CI on each deploy; leave "latest" for manual runs
IMAGE_TAG=latest

# Postgres (used by db service and app DATABASE_URL in compose)
POSTGRES_PASSWORD=change-me-long-random

# Public site (Caddy automatic HTTPS). Leave empty to serve HTTP on :80 only.
DOMAIN=new.spider.si
# Docker UI (Portainer) — DNS A record → same server, gray cloud (DNS-only) for Caddy TLS
PORTAINER_DOMAIN=admin-dash.spider.si
ACME_EMAIL=you@example.com

# App
SESSION_COOKIE_NAME=spider_session
SESSION_LIFETIME_DAYS=14
SESSION_COOKIE_SECURE=true
# Comma-separated; include https://DOMAIN when using TLS
CORS_ORIGINS=https://new.spider.si
SCRAPE_INTERVAL_SECONDS=60
SCRAPER_USER_AGENT=spider-bot/0.1 (+https://new.spider.si)

# Avto.net via self-hosted Firecrawl (deploy/firecrawl-prod.sh on the VPS)
# FIRECRAWL_API_URL=http://firecrawl-api:3002
# AVTONET_FETCH_MODE=firecrawl
# FIRECRAWL_BULL_AUTH_KEY=change-me-long-random
# Cloud Firecrawl instead:
# FIRECRAWL_API_URL=https://api.firecrawl.dev
# FIRECRAWL_API_KEY=
# SCRAPERAPI_API_KEY=

# Telegram notifications (optional)
# 1. Message @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=
# 2. openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
# 3. Must match public HTTPS origin (api registers webhook on startup)
TELEGRAM_WEBHOOK_BASE_URL=https://new.spider.si
TELEGRAM_POLLING=false
TELEGRAM_LINK_TOKEN_TTL_MINUTES=15
