# Copy to /opt/spider/.env on the Hetzner server (never commit .env).

# GHCR image (lowercase), e.g. ghcr.io/youruser/spider-python
SPIDER_IMAGE=ghcr.io/YOUR_GITHUB_USER/spider-python
# Set by CI on each deploy; leave "latest" for manual runs
IMAGE_TAG=latest

# Postgres (used by db service and app DATABASE_URL in compose)
POSTGRES_PASSWORD=change-me-long-random

# Public site (Caddy automatic HTTPS). Comma-separated hosts on one block.
DOMAIN=spider.si, new.spider.si, www.spider.si
# Docker UI (Portainer) — DNS A record → same server, gray cloud (DNS-only) for Caddy TLS
PORTAINER_DOMAIN=admin-dash.spider.si
# Twenty CRM — DNS A record crm → same server, gray cloud (DNS-only) for Caddy TLS
TWENTY_DOMAIN=crm.spider.si
TWENTY_SERVER_URL=https://crm.spider.si
TWENTY_TAG=latest
TWENTY_PG_USER=twenty
TWENTY_PG_DATABASE=twenty
# openssl rand -base64 32 (no special chars in password is safest for URLs)
TWENTY_PG_PASSWORD=change-me-long-random
TWENTY_ENCRYPTION_KEY=change-me-openssl-rand-base64-32
# TWENTY_APP_SECRET=  # optional when TWENTY_ENCRYPTION_KEY is set
# n8n — DNS A record n8n → same server, gray cloud (DNS-only) for Caddy TLS
N8N_DOMAIN=n8n.spider.si
N8N_HOST=n8n.spider.si
N8N_WEBHOOK_URL=https://n8n.spider.si/
N8N_TAG=latest
N8N_PG_USER=n8n
N8N_PG_DATABASE=n8n
N8N_PG_PASSWORD=change-me-long-random
N8N_ENCRYPTION_KEY=change-me-openssl-rand-hex-32
N8N_JWT_SECRET=change-me-openssl-rand-hex-32
N8N_TIMEZONE=Europe/Ljubljana
# Twenty CRM credential in n8n UI: API URL https://crm.spider.si (no /rest suffix)
# Create key in Twenty → Settings → Developers → API & Webhooks
ACME_EMAIL=you@example.com

# App
SESSION_COOKIE_NAME=spider_session
SESSION_LIFETIME_DAYS=14
SESSION_COOKIE_SECURE=true
# Comma-separated; include every public origin users hit in the browser
CORS_ORIGINS=https://spider.si,https://www.spider.si,https://new.spider.si
SCRAPE_INTERVAL_SECONDS=60
SCRAPER_USER_AGENT=spider-bot/0.1 (+https://spider.si)

# Avto.net via self-hosted Firecrawl (deploy/firecrawl-prod.sh on the VPS)
# FIRECRAWL_API_URL=http://firecrawl-api:3002
# AVTONET_FETCH_MODE=firecrawl
# FIRECRAWL_BULL_AUTH_KEY=change-me-long-random
# Cloud Firecrawl instead:
# FIRECRAWL_API_URL=https://api.firecrawl.dev
# FIRECRAWL_API_KEY=
# SCRAPERAPI_API_KEY=

# Telegram notifications (optional)
# 1. Message @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=
# 2. openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
# 3. Must match public HTTPS origin (api registers webhook on startup)
TELEGRAM_WEBHOOK_BASE_URL=https://spider.si
TELEGRAM_POLLING=false
TELEGRAM_LINK_TOKEN_TTL_MINUTES=15
