DATABASE_URL=postgresql+asyncpg://spider:spider@localhost:5435/spider
ALEMBIC_DATABASE_URL=postgresql+psycopg://spider:spider@localhost:5435/spider
SESSION_COOKIE_NAME=spider_session
SESSION_LIFETIME_DAYS=14
SESSION_COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:5173
SCRAPE_INTERVAL_SECONDS=60
SCRAPER_USER_AGENT=spider-bot/0.1 (+https://example.com)

# Cloudflare API (DNS management for spider.si) — copy real token to .env only
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_NAME=spider.si

# Production (Hetzner): see deploy/README.md and deploy/env.example
