DATABASE_URL=postgresql+asyncpg://spider:spider@localhost:5435/spider
ALEMBIC_DATABASE_URL=postgresql+psycopg://spider:spider@localhost:5435/spider
SESSION_COOKIE_NAME=spider_session
SESSION_LIFETIME_DAYS=14
SESSION_COOKIE_SECURE=false
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
SCRAPE_INTERVAL_SECONDS=60
SCRAPER_USER_AGENT=spider-bot/0.1 (+https://example.com)

# avto.net lookahead probe (make avtonet / avto.net.lookahead worker)
AVTONET_LOOKAHEAD_START_ID=22421224
AVTONET_LOOKAHEAD_BATCH_SIZE=10
AVTONET_PROBE_DELAY_SECONDS=0
AVTONET_LOOKAHEAD_IDLE_SECONDS=5

# avto.net fetch: auto | direct | scraperapi | firecrawl
# auto = firecrawl if FIRECRAWL_API_KEY set, else scraperapi, else direct
AVTONET_FETCH_MODE=auto

# Firecrawl (avto.net) — cloud or self-hosted (make firecrawl-up → http://127.0.0.1:3002)
FIRECRAWL_API_URL=https://api.firecrawl.dev
# FIRECRAWL_API_URL=http://127.0.0.1:3002
FIRECRAWL_API_KEY=

# ScraperAPI (avto.net / Cloudflare WAF) — https://www.scraperapi.com/
SCRAPERAPI_API_KEY=
# SCRAPERAPI_PREMIUM=true
# SCRAPERAPI_RENDER=true
# SCRAPERAPI_COUNTRY_CODE=si

# Cloudflare API (DNS management for spider.si) — copy real token to .env only
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_NAME=spider.si
# Optional; if unset, account id is resolved from CLOUDFLARE_ZONE_NAME
# CLOUDFLARE_ACCOUNT_ID=0d7dffce2be6f0421d262a37f51daabe

# Telegram (optional) — create bot via @BotFather, then set token here
TELEGRAM_BOT_TOKEN=
# Random secret; Telegram sends as X-Telegram-Bot-Api-Secret-Token on webhook calls
TELEGRAM_WEBHOOK_SECRET=
# Public API base URL for webhook registration (prod), e.g. https://new.spider.si
TELEGRAM_WEBHOOK_BASE_URL=
# Local dev without public URL: set true to poll getUpdates instead of webhook
TELEGRAM_POLLING=false
TELEGRAM_LINK_TOKEN_TTL_MINUTES=15

# Production (Hetzner): see deploy/README.md and deploy/env.example
